<!DOCTYPE html>
<html lang="{{ locale }}">
<head>
<meta charset="UTF-8"/>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }

body {
    font-family: "DejaVu Sans", Arial, sans-serif;
    font-size: 11px;
    color: #2d2d2d;
    background: #fff;
    line-height: 1.5;
}

/* ── Header ── */
.header {
    background: #1a1a2e;
    color: #fff;
    padding: 16px 24px;
    margin-bottom: 22px;
}
.header-inner {
    width: 100%;
}
.header .shop-name {
    font-size: 17px;
    font-weight: bold;
    letter-spacing: 0.5px;
}
.header .doc-label {
    font-size: 9px;
    opacity: 0.65;
    margin-top: 2px;
    text-transform: uppercase;
    letter-spacing: 1px;
}

/* ── Page wrapper ── */
.page-body {
    padding: 0 24px 24px 24px;
}

/* ── Product overview (image + key info) ── */
.overview-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 20px;
}
.overview-table td {
    vertical-align: top;
    padding: 0;
}
.img-cell {
    width: 38%;
    padding-right: 24px;
}
.img-cell img {
    max-width: 100%;
    max-height: 210px;
    border: 1px solid #e0e0e0;
    border-radius: 4px;
}
.img-placeholder {
    width: 100%;
    height: 190px;
    background: #f4f4f4;
    border: 1px dashed #ccc;
    text-align: center;
    padding-top: 80px;
    color: #aaa;
    font-size: 10px;
    border-radius: 4px;
}
.info-cell {
    width: 62%;
    padding-left: 24px;
    border-left: 2px solid #e8e8e8;
}
.product-name {
    font-size: 18px;
    font-weight: bold;
    color: #1a1a2e;
    margin-bottom: 6px;
    line-height: 1.3;
}
.product-sku {
    font-size: 10px;
    color: #777;
    margin-bottom: 14px;
    letter-spacing: 0.3px;
}
.price-gross {
    font-size: 22px;
    font-weight: bold;
    color: #c0392b;
    margin-bottom: 2px;
}
.price-net {
    font-size: 10px;
    color: #888;
    margin-bottom: 14px;
}
.meta-row {
    font-size: 10px;
    color: #555;
    margin-top: 5px;
}
.meta-row strong {
    color: #333;
}

/* ── Section title ── */
.section-title {
    font-size: 12px;
    font-weight: bold;
    color: #1a1a2e;
    border-bottom: 2px solid #1a1a2e;
    padding-bottom: 4px;
    margin-top: 22px;
    margin-bottom: 10px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

/* ── Description ── */
.description {
    font-size: 10.5px;
    color: #444;
    line-height: 1.65;
}

/* ── Properties & custom fields ── */
.prop-table {
    width: 100%;
    border-collapse: collapse;
}
.prop-table tr:nth-child(odd) td {
    background: #f8f8f8;
}
.prop-table td {
    padding: 5px 8px;
    font-size: 10.5px;
    border-bottom: 1px solid #ebebeb;
}
.prop-table .prop-key {
    font-weight: bold;
    color: #444;
    width: 36%;
}

/* ── Variants ── */
.variant-table {
    width: 100%;
    border-collapse: collapse;
}
.variant-table th {
    background: #1a1a2e;
    color: #fff;
    padding: 6px 8px;
    font-size: 10px;
    text-align: left;
    font-weight: normal;
    text-transform: uppercase;
    letter-spacing: 0.4px;
}
.variant-table td {
    padding: 5px 8px;
    font-size: 10.5px;
    border-bottom: 1px solid #ebebeb;
}
.variant-table tr:nth-child(even) td {
    background: #f9f9f9;
}

/* ── Footer ── */
.footer {
    margin-top: 30px;
    padding-top: 8px;
    border-top: 1px solid #ddd;
    font-size: 9px;
    color: #aaa;
    text-align: center;
}
</style>
</head>
<body>

{# ── Header ── #}
<div class="header">
    <table class="header-inner"><tr>
        <td><div class="shop-name">{{ shopName }}</div>
            <div class="doc-label">{{ labels.docLabel }}</div></td>
    </tr></table>
</div>

<div class="page-body">

{# ── Product overview ── #}
<table class="overview-table">
<tr>
    <td class="img-cell">
        {% if imageDataUri %}
            <img src="{{ imageDataUri }}" alt="{{ product.name }}"/>
        {% else %}
            <div class="img-placeholder">{{ labels.noImage }}</div>
        {% endif %}
    </td>
    <td class="info-cell">
        <div class="product-name">{{ product.name }}</div>
        <div class="product-sku">{{ labels.articleNumber }}: {{ product.productNumber }}</div>

        {% if priceGross %}
            <div class="price-gross">{{ priceGross }}</div>
        {% endif %}
        {% if priceNet %}
            <div class="price-net">{{ priceNet }} ({{ labels.net }})
                {% if product.tax %} · {{ product.tax.taxRate }}% {{ labels.vat }}{% endif %}
            </div>
        {% endif %}

        {% if product.manufacturer %}
        <div class="meta-row"><strong>{{ labels.manufacturer }}:</strong> {{ product.manufacturer.name }}</div>
        {% endif %}

        {% if product.stock is not null %}
        <div class="meta-row"><strong>{{ labels.stock }}:</strong> {{ product.stock }}</div>
        {% endif %}

        {% if product.ean %}
        <div class="meta-row"><strong>EAN:</strong> {{ product.ean }}</div>
        {% endif %}

        {% if product.weight %}
        <div class="meta-row"><strong>{{ labels.weight }}:</strong> {{ product.weight }} kg</div>
        {% endif %}
    </td>
</tr>
</table>

{# ── Description ── #}
{% set desc = product.description %}
{% if desc %}
<div class="section-title">{{ labels.description }}</div>
<div class="description">{{ desc|striptags('<p><br><strong><em><b><i><ul><ol><li>')|raw }}</div>
{% endif %}

{# ── Properties ── #}
{% if properties is not empty %}
<div class="section-title">{{ labels.properties }}</div>
<table class="prop-table">
{% for groupName, values in properties %}
<tr>
    <td class="prop-key">{{ groupName }}</td>
    <td>{{ values|join(', ') }}</td>
</tr>
{% endfor %}
</table>
{% endif %}

{# ── Variants ── #}
{% if variants is not empty %}
<div class="section-title">{{ labels.variants }}</div>
<table class="variant-table">
<thead>
<tr>
    <th>{{ labels.variantCol }}</th>
    <th>{{ labels.articleCol }}</th>
    <th>{{ labels.priceCol }}</th>
    <th>{{ labels.stockCol }}</th>
</tr>
</thead>
<tbody>
{% for v in variants %}
<tr>
    <td>{{ v.options }}</td>
    <td>{{ v.productNumber }}</td>
    <td>{{ v.price }}</td>
    <td>{{ v.stock }}</td>
</tr>
{% endfor %}
</tbody>
</table>
{% endif %}

{# ── Custom fields ── #}
{% if customFields is not empty %}
<div class="section-title">{{ labels.customFields }}</div>
<table class="prop-table">
{% for label, value in customFields %}
<tr>
    <td class="prop-key">{{ label }}</td>
    <td>{{ value }}</td>
</tr>
{% endfor %}
</table>
{% endif %}

{# ── Footer ── #}
<div class="footer">
    {{ shopName }} &nbsp;·&nbsp; {{ labels.generatedAt }} {{ generatedAt }}
</div>

</div>{# /page-body #}
</body>
</html>
